TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── LLM Provider ──
# Set to "google" (default) or "openai"
LLM_PROVIDER=google

# Google AI Studio (Gemini) — get yours at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI (alternative — only needed if LLM_PROVIDER=openai)
# OPENAI_API_KEY=your_openai_api_key_here
